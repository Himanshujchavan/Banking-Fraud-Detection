# --- Database (existing) ---
DB_USER=postgres
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_bank

# --- Connection pool (new, optional) ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- CORS (new) ---
# Comma-separated list of allowed origins. Do not use "*" together with
# credentialed requests in production.
ALLOWED_ORIGINS=http://localhost:3000

# --- Schema bootstrap (new, dev only) ---
# If true, creates any missing tables on startup via SQLAlchemy metadata.
# Leave false in staging/prod and use migrate.py / Alembic instead.
AUTO_CREATE_TABLES=false

# --- Background fraud scans (new) ---
BACKGROUND_SCAN_INTERVAL_SECONDS=300
