# --- Database (existing) ---
DB_USER=postgres
DB_PASSWORD=12345678
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_bank

# --- Connection pool (new, optional) ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# --- CORS (new) ---
# Comma-separated list of allowed origins. Do not use "*" together with
# credentialed requests in production.
ALLOWED_ORIGINS=http://localhost:3000

# --- Schema bootstrap (new, dev only) ---
# If true, creates any missing tables on startup via SQLAlchemy metadata.
# Leave false in staging/prod and use migrate.py / Alembic instead.
AUTO_CREATE_TABLES=false

# --- Background fraud scans (new) ---
BACKGROUND_SCAN_INTERVAL_SECONDS=300

# --- Redis (new) ---
# Used for live WebSocket alert fan-out across API replicas.
REDIS_URL=redis://localhost:6379/0

# --- Kafka (new) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OUTBOX_POLL_INTERVAL_SECONDS=2
OUTBOX_BATCH_SIZE=100
AUDIT_CONSUMER_GROUP=audit-log-writer
CASE_AUTOMATION_CONSUMER_GROUP=case-automation
CASE_AUTO_CREATE_THRESHOLD=85
