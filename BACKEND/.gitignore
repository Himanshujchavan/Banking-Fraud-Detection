```gitignore
# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Runtime files
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.next/
turbo/

# Uploads
uploads/
temp/
tmp/

# Database files
*.sqlite
*.db

# Python (if using FastAPI)
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
ENV/
.pytest_cache/

# IDEs
.vscode/*
!.vscode/extensions.json
.idea/

# OS files
.DS_Store
Thumbs.db

# Misc
*.local
.vercel

# Docker
docker-compose.override.yml

# TypeScript
*.tsbuildinfo
```
